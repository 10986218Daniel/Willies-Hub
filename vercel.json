{
  "version": 2,
  "builds": [
    {
      "src": "customer-site/**",
      "use": "@vercel/static"
    },
    {
      "src": "owner-site/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/customer-site/assets/$1"
    },
    {
      "src": "/cart",
      "dest": "/customer-site/cart.html"
    },
    {
      "src": "/cart.html",
      "dest": "/customer-site/cart.html"
    },
    {
      "src": "/product",
      "dest": "/customer-site/product.html"
    },
    {
      "src": "/product.html",
      "dest": "/customer-site/product.html"
    },
    {
      "src": "/index.html",
      "dest": "/customer-site/index.html"
    },
    {
      "src": "/owner-site",
      "dest": "/owner-site/index.html"
    },
    {
      "src": "/customer-site",
      "dest": "/customer-site/index.html"
    },
    {
      "src": "/owner",
      "dest": "/owner-site/index.html"
    },
    {
      "src": "/customer-site/(.*)",
      "dest": "/customer-site/$1"
    },
    {
      "src": "/owner-site/(.*)",
      "dest": "/owner-site/$1"
    },
    {
      "src": "/",
      "dest": "/customer-site/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/customer-site/index.html"
    }
  ]
}